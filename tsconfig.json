{
  "compileOnSave": false,
  "compilerOptions": {
    "strict": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2022",
    "module": "preserve",
    "paths": {
      "@spartan-ng/helm/button": [
        "./src/app/components/helm/button/src/index.ts"
      ],
      "@spartan-ng/helm/utils": [
        "./src/app/components/helm/utils/src/index.ts"
      ],
      "@spartan-ng/helm/input": [
        "./src/app/components/helm/input/src/index.ts"
      ],
      "@spartan-ng/helm/label": [
        "./src/app/components/helm/label/src/index.ts"
      ],
      "@spartan-ng/helm/select": [
        "./src/app/components/helm/select/src/index.ts"
      ],
      "@spartan-ng/helm/icon": [
        "./src/app/components/helm/icon/src/index.ts"
      ],
      "@spartan-ng/helm/switch": [
        "./src/app/components/helm/switch/src/index.ts"
      ],
      "@spartan-ng/helm/badge": [
        "./src/app/components/helm/badge/src/index.ts"
      ],
      "@spartan-ng/helm/card": [
        "./src/app/components/helm/card/src/index.ts"
      ],
      "@spartan-ng/helm/dialog": [
        "./src/app/components/helm/dialog/src/index.ts"
      ],
      "@spartan-ng/helm/separator": [
        "./src/app/components/helm/separator/src/index.ts"
      ],
      "@spartan-ng/helm/progress": [
        "./src/app/components/helm/progress/src/index.ts"
      ],
      "@spartan-ng/helm/scroll-area": [
        "./src/app/components/helm/scroll-area/src/index.ts"
      ],
      "@spartan-ng/helm/toggle": [
        "./src/app/components/helm/toggle/src/index.ts"
      ]
    }
  },
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false,
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true,
    "typeCheckHostBindings": true,
    "strictTemplates": true
  },
  "files": [],
  "references": [
    {
      "path": "./tsconfig.app.json"
    }
  ]
}
